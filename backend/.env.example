# --- Production (e.g. Railway) ---
# NODE_ENV=production
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname   (Railway provides this when you add PostgreSQL)
# FRONTEND_URL=https://your-site.netlify.app
# PUBLIC_URL=https://your-strapi.up.railway.app   (Strapi public URL for OAuth and cookies; required behind proxy)

# --- Discord OAuth (guild restriction) ---
# DISCORD_ALLOWED_GUILD_ID=your-feedforward-discord-server-id
